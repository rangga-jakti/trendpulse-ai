# =============================================================
# TrendPulse AI - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================

# Django
SECRET_KEY=your-super-secret-django-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=trendpulse_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432

# Redis (for Celery + Cache)
REDIS_URL=redis://127.0.0.1:6379/0

# AI/LLM - Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Alternatively use OpenAI:
# OPENAI_API_KEY=your_openai_api_key_here

# NewsAPI - Get your key at https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# Google Trends (pytrends - no API key required)
# Optional: proxy settings if rate limited
# PYTRENDS_PROXY=http://your-proxy:port

# App Settings
TRENDS_FETCH_INTERVAL=900  # 15 minutes in seconds
MAX_TRENDS_PER_FETCH=20
VIRALITY_SCORE_THRESHOLD=60
